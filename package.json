{
  "name": "cravingcrawler",
  "version": "0.1.0",
  "dependencies": {
    "@astrojs/node": "^9.5.4",
    "@picocss/pico": "^2.1.0",
    "astro": "^5.7.0",
    "cheerio": "^1.0.0-rc.12",
    "discord.js": "^14.11.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "yaml": "^2.2.1",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "description": "Track limited-time treats — scraper + web dashboard in one Bun app",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bunx --bun astro dev",
    "start": "bunx --bun astro build && bun ./dist/server/entry.mjs",
    "build": "bunx --bun astro build",
    "preview": "bunx --bun astro preview",
    "test": "bun test",
    "schedule": "bun run src/scheduler.ts --config config.yml",
    "schedule:loop": "bun run src/scheduler.ts --loop --config config.yml",
    "scrape": "bun run src/cli.ts",
    "validate": "bun run src/scheduler.ts --data-dir /tmp/cc-validate",
    "validate:site": "bun run src/scheduler.ts --data-dir /tmp/cc-validate --only-site"
  },
  "type": "module"
}
