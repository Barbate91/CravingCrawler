{
  "name": "cravingcrawler",
  "version": "0.1.0",
  "description": "Small, configurable scraper for dessert specials (Bun + TypeScript)",
  "type": "module",
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --outdir dist",
    "schedule": "bun run src/scheduler.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "yaml": "^2.2.1",
    "yargs": "^17.7.2",
    "discord.js": "^14.11.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
