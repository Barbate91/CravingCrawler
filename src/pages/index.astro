---
import Base from "../layouts/Base.astro";
import { loadAllLatest } from "../lib/data";
import { loadWebConfig } from "../lib/web-config";
import type { SiteSummary } from "../lib/data";

const config = await loadWebConfig();
const summaries = await loadAllLatest();
const totalItems = summaries.reduce((sum, s) => sum + s.items.length, 0);
const emojis = ["🍪", "🧁", "🍰", "🍩", "🎂", "🍫"];
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Group summaries by site name
const siteGroups = new Map<string, SiteSummary[]>();
for (const s of summaries) {
  const group = siteGroups.get(s.site) ?? [];
  group.push(s);
  siteGroups.set(s.site, group);
}
const siteCount = siteGroups.size;

// Freshness: hours since last successful scrape per shop (max across regions)
function hoursAgo(iso: string | null): number | null {
  if (!iso) return null;
  return (Date.now() - new Date(iso).getTime()) / 3_600_000;
}
function freshnessLabel(iso: string | null): string {
  const h = hoursAgo(iso);
  if (h === null) return "unknown";
  if (h < 1) return "just now";
  if (h < 24) return `${Math.round(h)}h ago`;
  return `${Math.round(h / 24)}d ago`;
}
function freshnessClass(iso: string | null): string {
  const h = hoursAgo(iso);
  if (h === null) return "fresh-unknown";
  if (h < 24) return "fresh-ok";
  if (h < 72) return "fresh-stale";
  return "fresh-old";
}
const shopChips = [...siteGroups.entries()].map(([site, group]) => {
  const newest = group
    .map((g) => g.scrapedAt)
    .filter((t): t is string => !!t)
    .sort()
    .reverse()[0] ?? null;
  return {
    site,
    label: site.replace(/-/g, " "),
    region: group[0].region,
    itemCount: group.reduce((n, g) => n + g.items.length, 0),
    scrapedAt: newest,
  };
});

// Flatten all items into a single list, tagged with site info
const allCards = summaries.flatMap((s) =>
  s.items.map((item) => ({
    ...item,
    site: s.site,
    region: s.region,
    siteLabel: s.site.replace(/-/g, " "),
    hasImages: s.items.some((i) => !!i.image),
  }))
);
---

<Base title="CravingCrawler — Current Treats">
  {!config.configFound && (
    <div class="banner banner-warning">
      <p><strong>&#9888; Configuration not found.</strong> No <code>config.yml</code> was detected. Create one to define your sites and scrape targets.</p>
    </div>
  )}

  {config.configFound && !config.hasTargets && (
    <div class="banner banner-warning">
      <p><strong>&#9888; No scrape targets configured.</strong> Your <code>config.yml</code> has {config.siteCount} site definition(s) but no enabled targets.</p>
    </div>
  )}

  {config.hasTargets && summaries.length === 0 && (
    <div class="banner banner-info">
      <p><strong>&#8505; Waiting for first scrape.</strong> {config.enabledTargetCount} target(s) configured &mdash; data will appear here after the first run.</p>
    </div>
  )}

  <div class="hero">
    <h1>What&rsquo;s Fresh Today</h1>
    {summaries.length > 0 ? (
      <div>
        <span class="stat"><strong>{totalItems}</strong> treats</span>
        <span class="stat"><strong>{siteCount}</strong> {siteCount === 1 ? "shop" : "shops"}</span>
      </div>
    ) : (
      <p>No treat data to display yet. The scraper will populate this page automatically.</p>
    )}
  </div>

  {shopChips.length > 0 && (
    <div class="shop-chips">
      {shopChips.map((c) => (
        <a href={`${base}/site/${c.site}/${c.region}`} class={`shop-chip ${freshnessClass(c.scrapedAt)}`} title={c.scrapedAt ? `Last scraped ${new Date(c.scrapedAt).toLocaleString()}` : "No scrape timestamp"}>
          <span class="chip-name">{c.label}</span>
          <span class="chip-count">{c.itemCount}</span>
          <span class="chip-fresh">{freshnessLabel(c.scrapedAt)}</span>
        </a>
      ))}
    </div>
  )}

  {allCards.length > 0 && (
    <div class="item-grid">
      {allCards.map((item, i) => {
        const imgSrc = item.image?.startsWith("/") ? `${base}${item.image}` : item.image;
        return (
          <div class="item-card">
            {item.image ? (
              <img src={imgSrc} alt={item.title} class="card-image" loading="lazy" />
            ) : item.hasImages ? (
              <div class="card-no-image">{emojis[i % emojis.length]}</div>
            ) : (
              <div class="card-no-image text-placeholder">{item.title}</div>
            )}
            <div class="card-body">
              <a href={`${base}/site/${item.site}/${item.region}`} class="card-site-label">{item.siteLabel}</a>
              <h3 class="card-title">{item.title}</h3>
              {item.price && <div class="card-price">{item.price}</div>}
              {item.description && (
                <div>
                  <p class="card-desc">{item.description}</p>
                  <button class="card-expand-btn" aria-label="Toggle description">
                    <span class="expand-text">Show more</span>
                    <span class="collapse-text">Show less</span>
                  </button>
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  )}
</Base>
